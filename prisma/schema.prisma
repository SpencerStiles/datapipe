generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pipeline {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @default("")
  schedule    String   @default("") // cron expression or empty for manual
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps Step[]
  runs  Run[]

  @@index([slug])
}

model Step {
  id         String @id @default(cuid())
  pipelineId String
  name       String
  type       String @default("extract") // extract, transform, load, filter, map, aggregate
  config     String @default("{}") // JSON config for the step
  order      Int    @default(0)

  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId])
  @@index([order])
}

model Run {
  id         String   @id @default(cuid())
  pipelineId String
  status     String   @default("pending") // pending, running, success, failed, cancelled
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  duration   Int?     // milliseconds
  rowsIn     Int      @default(0)
  rowsOut    Int      @default(0)
  error      String   @default("")

  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  logs       Log[]

  @@index([pipelineId])
  @@index([status])
  @@index([startedAt])
}

model Log {
  id        String   @id @default(cuid())
  runId     String
  level     String   @default("info") // debug, info, warn, error
  message   String
  meta      String   @default("") // JSON metadata
  createdAt DateTime @default(now())

  run       Run      @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([level])
}

// ─── NextAuth Models ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
